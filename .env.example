# ========================================
# InfraGen — Environment Variables
# Copy to .env and fill in your values
# ========================================

# --- Database ---
POSTGRES_USER=infragen
POSTGRES_PASSWORD=infragen_local_dev
POSTGRES_DB=infragen
DATABASE_URL=postgresql+asyncpg://infragen:infragen_local_dev@postgres:5432/infragen

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=infragen-artifacts

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- App ---
APP_NAME=InfraGen
APP_ENV=development
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]
